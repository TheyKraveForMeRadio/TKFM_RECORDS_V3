
<!doctype html>

<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>TKFM Owner Analytics</title>
<link rel="stylesheet" href="/css/tkfm-shell.css" />
<link rel="stylesheet" href="/css/tkfm-records.css" />
<script src="/js/tkfm-shell.js" defer></script>
<script src="/js/tkfm-owner-guard.js"></script>
<script src="/js/tkfm-owner-gate-no-redirect.js"></script>
<script src="/js/tkfm-owner-nav.js"></script>
  <meta name="tkfm-lane" content="records-only">
  <script src="/js/tkfm-records-autoload.js"></script>
</head>
<body class="tkfm-records-root" data-tkfm-theme="records">
<div id="tkfmOwnerLock"></div>
<div id="tkfm-header"></div>
<main class="tkfm-main">
<h1>Owner Analytics Dashboard</h1>
<section id="analytics-sections">
<div id="pageviews-analytics"></div>
<div id="feature-sales-analytics"></div>
<div id="roster-activity-analytics"></div>
<div id="slot-usage-analytics"></div>
</section>
</main>
<div id="tkfm-footer"></div>
<script src="/js/tkfm-analytics-handler.js"></script>
</body>
</html>

<!doctype html><html lang="en"><head><meta charset="utf-8" /><meta name="viewport" content="width=device-width,initial-scale=1" /><title>TKFM Records — Label Home</title><meta name="description" content="TKFM Records — professional label operations, workflows, and paid lanes for approved members." /><style>:root{--bg:#020617;--gold:#facc15;--gold2:#eab308;--amber:#f97316;--panel:rgba(2,6,23,.84);--stroke:rgba(148,163,184,.18);--text:rgba(226,232,240,1);--muted:rgba(148,163,184,.95);--ok:#10b981;--warn:#f59e0b;--danger:#ef4444;--r:26px;--shadow:0 0 0 1px rgba(255,255,255,.04),0 18px 60px rgba(0,0,0,.48)}*{box-sizing:border-box}html,body{height:100%}body{margin:0;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,"Apple Color Emoji","Segoe UI Emoji";color:var(--text);background:var(--bg);overflow-x:hidden}a{color:inherit;text-decoration:none}img{max-width:100%;display:block}button{font-family:inherit}.bg{position:fixed;inset:0;z-index:-5;background:radial-gradient(900px 560px at 12% 8%,rgba(250,204,21,.16),transparent 60%),radial-gradient(900px 560px at 86% 14%,rgba(249,115,22,.11),transparent 60%),radial-gradient(900px 560px at 45% 94%,rgba(234,179,8,.12),transparent 60%),radial-gradient(1100px 650px at 70% 70%,rgba(250,204,21,.08),transparent 70%)}.bg:before{content:"";position:absolute;inset:-25%;background:repeating-linear-gradient(0deg,rgba(250,204,21,.08) 0px,rgba(250,204,21,.08) 1px,transparent 1px,transparent 30px),repeating-linear-gradient(90deg,rgba(249,115,22,.06) 0px,rgba(249,115,22,.06) 1px,transparent 1px,transparent 36px);transform:rotate(-6deg);opacity:.22;animation:grid 16s linear infinite;pointer-events:none}.bg:after{content:"";position:absolute;inset:-10%;background:radial-gradient(closest-side at 22% 28%,rgba(250,204,21,.18),transparent 70%),radial-gradient(closest-side at 70% 18%,rgba(249,115,22,.12),transparent 72%),radial-gradient(closest-side at 42% 82%,rgba(234,179,8,.12),transparent 74%);filter:blur(10px);opacity:.95;animation:wave 10.5s ease-in-out infinite;pointer-events:none}@keyframes grid{0%{transform:translate3d(-1%,-1%,0) rotate(-6deg)}50%{transform:translate3d(1.5%,1%,0) rotate(-6deg)}100%{transform:translate3d(-1%,-1%,0) rotate(-6deg)}}@keyframes wave{0%,100%{transform:translate3d(0,0,0) scale(1)}50%{transform:translate3d(1.2%,-1.1%,0) scale(1.02)}}.floaters{position:fixed;inset:0;z-index:-4;pointer-events:none;overflow:hidden}.float{position:absolute;width:600px;height:600px;border-radius:999px;filter:blur(46px);opacity:.10;background:radial-gradient(circle at 35% 35%,rgba(250,204,21,.95),transparent 60%)}.wrap{max-width:1240px;margin:0 auto;padding:24px}.topbar{position:sticky;top:0;z-index:90;background:rgba(0,0,0,.70);backdrop-filter:blur(14px);border-bottom:1px solid rgba(30,41,59,.65)}.brand img{height:44px}.pill{padding:10px 14px;border-radius:999px;border:1px solid rgba(148,163,184,.28);background:rgba(15,23,42,.62);font-size:11px;letter-spacing:.22em;text-transform:uppercase}.wm{position:absolute;right:-40px;bottom:-60px;width:340px;height:340px;opacity:.07}</style>
<script src="/js/tkfm-fx.js"></script>
<script src="/js/tkfm-quick-checkout.js"></script>
<script src="/js/tkfm-paid-lane-modal.js" defer></script>
<script src="/js/tkfm-paid-lane-submit.js" defer></script>
<script>window.__TKFM_DISABLE_OWNER_GATE = true;</script>
  <meta name="tkfm-lane" content="records-only">
  <script src="/js/tkfm-records-autoload.js"></script>
</head>
<body data-tkfm-theme="label">
<a href="/dashboard.html" style="position:fixed; right:16px; bottom:16px; z-index:9999; padding:10px 12px; border-radius:999px; font-weight:1000; color:#020617; background:linear-gradient(90deg,#22d3ee,#3b82f6)">Dashboard</a>
<script>window.TKFM_FX&&TKFM_FX.mount({ theme: 'label' });</script>
<img class="wm" src="/tkfm-records-logo.png" alt="">
<script src="/js/tkfm-checkout.js"></script>
<script src="/js/tkfm-paid-lane-modal.js"></script>
<script src="/js/tkfm-label-studio-cta.js"></script>
<script src="/js/tkfm-owner-override.js"></script>
</body></html>

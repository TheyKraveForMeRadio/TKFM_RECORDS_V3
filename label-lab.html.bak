<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>TKFM Records · Label Lab (Owner Console V3)</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="description" content="TKFM Records Label Lab — Owner Console V3. Upload releases, manage artists, track analytics." />

  <style>
    :root{
      --bg:#020617;
      --gold:#facc15;
      --gold2:#eab308;
      --orange:#f97316;
      --ink:#020617;
      --text:#e5e7eb;
      --muted:#9ca3af;
      --panel:rgba(2,6,23,.9);
      --stroke:rgba(250,204,21,.25);
      --r:22px;
      --shadow:0 25px 80px rgba(0,0,0,.6);
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:system-ui,-apple-system,Segoe UI,Roboto,Ubuntu,Helvetica,Arial;
      background:radial-gradient(900px 500px at 15% 10%,rgba(250,204,21,.15),transparent 60%),
                 radial-gradient(900px 500px at 85% 80%,rgba(249,115,22,.12),transparent 60%),
                 var(--bg);
      color:var(--text);
    }
    header{
      padding:26px 40px;
      border-bottom:1px solid var(--stroke);
      display:flex;
      align-items:center;
      justify-content:space-between;
    }
    header h1{
      margin:0;
      font-size:22px;
      letter-spacing:.4px;
      color:var(--gold);
    }
    nav a{
      margin-left:18px;
      padding:10px 16px;
      border-radius:14px;
      border:1px solid var(--stroke);
      background:rgba(250,204,21,.06);
    }
    main{
      max-width:1200px;
      margin:40px auto;
      padding:0 32px 80px;
    }
    .grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
      gap:28px;
    }
    .card{
      background:var(--panel);
      border-radius:var(--r);
      border:1px solid var(--stroke);
      box-shadow:var(--shadow);
      padding:26px;
    }
    .card h2{
      margin:0 0 8px;
      font-size:18px;
      color:var(--gold2);
    }
    .card p{
      margin:0 0 18px;
      color:var(--muted);
      font-size:14px;
    }
    .btn{
      display:inline-block;
      padding:12px 18px;
      border-radius:14px;
      background:linear-gradient(135deg,var(--gold),var(--orange));
      color:var(--ink);
      font-weight:700;
      border:none;
      cursor:pointer;
    }
    footer{
      padding:28px;
      text-align:center;
      color:var(--muted);
      border-top:1px solid var(--stroke);
    }
  </style>
  <meta name="tkfm-lane" content="records-only">
  <script src="/js/tkfm-records-autoload.js"></script>
</head>

<body>

<header>
  <h1>TKFM Records · Label Lab</h1>
  <nav>
    <a href="label-upload.html">Upload</a>
    <a href="label-analytics.html">Analytics</a>
    <a href="index.html">Public Gate</a>
  </nav>
</header>

<main>
  <div class="grid">

    <div class="card">
      <h2>Release Upload</h2>
      <p>Submit singles, mixtapes, artwork, metadata, and delivery options.</p>
      <a class="btn" href="label-upload.html">Open Upload Console</a>
    </div>

    <div class="card">
      <h2>Artist Management</h2>
      <p>View signed artists, release status, contracts, and payouts.</p>
      <button class="btn">Coming Online</button>
    </div>

    <div class="card">
      <h2>Performance Analytics</h2>
      <p>Track spins, revenue, promo packs, and catalog growth.</p>
      <a class="btn" href="label-analytics.html">View Analytics</a>
    </div>

    <div class="card">
      <h2>Owner Controls</h2>
      <p>Gate access, manage pricing tiers, and control visibility.</p>
      <button class="btn">Owner Only</button>
    </div>

  </div>
</main>

<footer>
  © TKFM Records · Owner Console V3
</footer>

</body>
</html>

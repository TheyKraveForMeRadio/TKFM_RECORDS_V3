<!doctype html>
<html lang="en" data-tkfm-theme="records">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <meta name="tkfm-lane" content="records-only">
  <title>TKFM Records — My Portal</title>
  <meta name="description" content="Your TKFM Records purchases, credits, requests, and deliverables."/>
  <style>
    :root{
      --bg:#020617;
      --g:#facc15; --ga:#f97316;
      --t:rgba(226,232,240,1); --m:rgba(148,163,184,.95);
      --stroke:rgba(148,163,184,.18);
      --panel:rgba(2,6,23,.78);
      --shadow:0 0 0 1px rgba(255,255,255,.04),0 22px 70px rgba(0,0,0,.55);
      --r:22px;
    }
    *{box-sizing:border-box}
    body{margin:0;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial;color:var(--t);background:var(--bg);min-height:100vh}
    a{color:inherit;text-decoration:none}
    .wrap{max-width:1160px;margin:0 auto;padding:18px 16px 70px}
    .glass{background:var(--panel);border:1px solid var(--stroke);border-radius:var(--r);backdrop-filter:blur(18px);box-shadow:var(--shadow)}
    header{position:sticky;top:0;z-index:20;background:rgba(0,0,0,.68);border-bottom:1px solid rgba(30,41,59,.65);backdrop-filter:blur(14px)}
    header .wrap{display:flex;align-items:center;gap:12px;padding:12px 16px}
    .logos img{height:42px;filter:drop-shadow(0 0 18px rgba(250,204,21,.25))}
    .title{font-weight:950;letter-spacing:.08em;text-transform:uppercase;font-size:12px}
    .sub{margin-top:2px;color:var(--m);font-size:12px}
    .nav{margin-left:auto;display:flex;gap:8px;flex-wrap:wrap}
    .pill{padding:9px 12px;border-radius:999px;border:1px solid rgba(148,163,184,.28);background:rgba(15,23,42,.62);font-size:11px;letter-spacing:.18em;text-transform:uppercase;font-weight:900}
    .pill:hover{border-color:rgba(250,204,21,.75)}
    .hero{margin-top:14px;padding:18px}
    .h1{margin:0;font-size:30px;font-weight:950}
    .p{margin:10px 0 0;color:var(--m);line-height:1.6}
    .grid{margin-top:14px;display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
    @media (max-width:980px){.grid{grid-template-columns:repeat(2,1fr)}}
    @media (max-width:720px){.grid{grid-template-columns:1fr}}
    .card{padding:16px;border-radius:20px}
    .k{font-size:10px;letter-spacing:.34em;text-transform:uppercase}
    .h{margin-top:8px;font-size:18px;font-weight:950}
    .d{margin-top:8px;color:var(--m);font-size:13px}
    .go{margin-top:12px;display:inline-flex;padding:9px 12px;border-radius:999px;border:1px solid rgba(148,163,184,.28);font-size:11px;font-weight:900}
    .go:hover{border-color:rgba(250,204,21,.75)}
  </style>

  <link rel="stylesheet" href="/css/tkfm-global-shell.css">
  <script src="/js/tkfm-pageviews.js"></script>
  <script src="/js/tkfm-global-shell.js" defer></script>
</head>
<body>

  <!-- Records FX Backgrounds (AUTO-WIRED) -->
  <div class="tkfm-bg-main"></div>
  <div class="tkfm-bg-orbit"></div>

  <header>
    <div class="wrap">
      <div class="logos">
        <img src="/tkfm-records-logo.png" alt="TKFM Records">
      </div>
      <div>
        <div class="title">TKFM Records — My Portal</div>
        <div class="sub">Purchases • Credits • Deliverables</div>
      </div>
      <div class="nav">
        <a class="pill" href="/index.html">Home</a>
        <a class="pill" href="/label-hub.html">Records Hub</a>
        <a class="pill" href="/pricing.html">Buy / Upgrade</a>
      </div>
    </div>
  </header>

  <main class="wrap">
    <section class="glass hero">
      <div class="h1">Everything you bought — organized.</div>
      <p class="p">Your TKFM Records tools, lanes, and deliverables live here.</p>
    </section>
  </main>

  <!-- Records Auto Loader (THEME + FX + SAFETY) -->
  <script src="/js/tkfm-records-autoload.js"></script>

</body>
</html>
